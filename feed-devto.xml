layout: null
permalink: /feed-devto.xml
---
{%- comment -%}
Dedicated feed for cross-posting to dev.to.

Differences from the canonical /feed.xml:
  - The series name is prefixed into the entry <title> ("Left of the Loop: The
    Metron"), so the series is visible on dev.to where there is no series widget.
  - The entry <link> carries ?ref=devto, so click-throughs from dev.to back to
    the blog show up as source "devto" in GoatCounter (mirrors ?ref=rss on the
    main feed). The <id> stays clean and stable so dev.to dedupes correctly and
    doesn't create duplicate drafts. Note: if you enable dev.to's "mark as
    canonical" option, the canonical_url it sets will include ?ref=devto.

Same as /feed.xml otherwise: 15 most recent published posts, full content.
future: false keeps scheduled (future-dated) posts out until their date.
{%- endcomment -%}
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="en">
  <title type="html">{{ site.title | smartify | xml_escape }} (dev.to)</title>
  <subtitle>{{ site.description | xml_escape }}</subtitle>
  <link href="{{ '/feed-devto.xml' | absolute_url }}" rel="self" type="application/atom+xml" />
  <link href="{{ '/' | absolute_url }}" rel="alternate" type="text/html" />
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <id>{{ '/feed-devto.xml' | absolute_url | xml_escape }}</id>
  <author>
    <name>{{ site.author.name | default: site.title | xml_escape }}</name>
  </author>
  {%- comment -%} limit: is a for-loop parameter, NOT a filter (`| limit` is a silent no-op). {%- endcomment -%}
  {%- for post in site.posts limit:15 %}
  <entry>
    {%- capture entry_title -%}{% if post.series %}{{ post.series }}: {% endif %}{{ post.title }}{%- endcapture -%}
    <title type="html">{{ entry_title | smartify | strip_html | normalize_whitespace | xml_escape }}</title>
    {%- comment -%} ?ref=devto tags dev.to click-throughs as source "devto" in GoatCounter. The <id> below stays clean so dev.to dedupes on a stable guid. {%- endcomment -%}
    <link href="{{ post.url | absolute_url }}?ref=devto" rel="alternate" type="text/html" title="{{ post.title | xml_escape }}" />
    <published>{{ post.date | date_to_xmlschema }}</published>
    <updated>{{ post.last_modified_at | default: post.date | date_to_xmlschema }}</updated>
    <id>{{ post.id | absolute_url | xml_escape }}</id>
    <content type="html" xml:base="{{ post.url | absolute_url | xml_escape }}">{{ post.content | strip | xml_escape }}</content>
    <author>
      <name>{{ post.author | first | default: site.author.name | xml_escape }}</name>
    </author>
    {%- for tag in post.tags %}
    <category term="{{ tag | xml_escape }}" />
    {%- endfor %}
  </entry>
  {%- endfor %}
</feed>
